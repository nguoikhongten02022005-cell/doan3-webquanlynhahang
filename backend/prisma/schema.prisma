generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  staff
  admin
}

enum TableStatus {
  AVAILABLE
  HELD
  OCCUPIED
  DIRTY
}

enum TableAreaId {
  SANH_CHINH
  PHONG_VIP
  BAN_CONG
  QUAY_BAR
}

enum BookingStatus {
  YEU_CAU_DAT_BAN
  GIU_CHO_TAM
  DA_XAC_NHAN
  CAN_GOI_LAI
  CHO_XAC_NHAN
  DA_GHI_NHAN
  DA_CHECK_IN
  DA_XEP_BAN
  TU_CHOI_HET_CHO
  DA_HUY
  KHONG_DEN
  DA_HOAN_THANH
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String
  username  String    @unique
  email     String    @unique
  password  String
  role      UserRole
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  orders    Order[]
}

model Table {
  id                String         @id
  code              String         @unique
  name              String
  areaId            TableAreaId
  capacity          Int
  status            TableStatus
  activeBookingId   Int?
  activeBookingCode String         @default("")
  occupiedAt        DateTime?
  releasedAt        DateTime?
  note              String         @default("")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  bookingLinks      BookingTable[]
}

model Booking {
  id                  Int            @id @default(autoincrement())
  bookingCode         String         @unique
  guests              String
  date                String
  time                String
  seatingArea         String         @default("KHONG_UU_TIEN")
  notes               String         @default("")
  name                String
  phone               String
  email               String         @default("")
  status              BookingStatus
  source              String         @default("web")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  userEmail           String?
  occasion            String         @default("")
  confirmationChannel Json?
  internalNote        String         @default("")
  checkedInAt         DateTime?
  seatedAt            DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  noShowAt            DateTime?
  createdBy           String         @default("")
  userId              Int?
  user                User?          @relation(fields: [userId], references: [id])
  bookingTables       BookingTable[]

  @@index([userId])
  @@index([status])
}

model BookingTable {
  bookingId  Int
  tableId    String
  assignedAt DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  table      Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([bookingId, tableId])
}

model MenuItem {
  id          Int      @id
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  badge       String   @default("Mới")
  tone        String   @default("tone-amber")
  image       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id                 Int         @id @default(autoincrement())
  subtotal           Decimal     @db.Decimal(10, 2)
  serviceFee         Decimal     @db.Decimal(10, 2)
  discountAmount     Decimal     @db.Decimal(10, 2)
  voucherCode        String      @default("")
  total              Decimal     @db.Decimal(10, 2)
  orderDate          DateTime    @default(now())
  status             String      @default("Mới Đặt")
  note               String      @default("")
  tableNumber        String      @default("")
  paymentMethod      String      @default("cash")
  userEmail          String      @default("")
  customerFullName   String      @default("")
  customerPhone      String      @default("")
  customerEmail      String      @default("")
  customerAddress    String      @default("")
  customerSnapshot   Json?
  userId             Int?
  user               User?       @relation(fields: [userId], references: [id])
  items              OrderItem[]

  @@index([userId])
}

model OrderItem {
  id               Int       @id @default(autoincrement())
  orderId          Int
  menuItemId       Int?
  name             String
  price            Decimal   @db.Decimal(10, 2)
  quantity         Int
  selectedSize     String    @default("M")
  selectedToppings Json?
  specialNote      String    @default("")
  variantKey       String    @default("")
  itemSnapshot     Json?
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem         MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Voucher {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  amount    Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
