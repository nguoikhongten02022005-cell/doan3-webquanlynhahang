generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  staff
  admin
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TableStatus {
  AVAILABLE
  HELD
  OCCUPIED
  DIRTY
}

enum BookingStatus {
  YEU_CAU_DAT_BAN
  GIU_CHO_TAM
  DA_XAC_NHAN
  CAN_GOI_LAI
  CHO_XAC_NHAN
  DA_GHI_NHAN
  DA_CHECK_IN
  DA_XEP_BAN
  TU_CHOI_HET_CHO
  DA_HUY
  KHONG_DEN
  DA_HOAN_THANH
}

enum VoucherDiscountType {
  FIXED
  PERCENTAGE
}

enum TrangThaiDonHang {
  MOI_TAO
  DA_XAC_NHAN
  DANG_CHUAN_BI
  DANG_PHUC_VU
  DA_HOAN_THANH
  DA_HUY
}

enum TrangThaiThanhToan {
  CHUA_THANH_TOAN
  DA_THANH_TOAN
  DA_HOAN_TIEN
}

enum PhuongThucThanhToan {
  TIEN_MAT
  CHUYEN_KHOAN
  THE
}

model User {
  id            Int            @id @default(autoincrement())
  fullName      String
  username      String         @unique
  email         String         @unique
  password      String
  role          UserRole
  status        UserStatus     @default(ACTIVE)
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  orders        Order[]
  refreshTokens RefreshToken[]

  @@index([role])
  @@index([status])
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @unique
  userId     Int
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TableArea {
  id          String   @id
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tables      Table[]
}

model Table {
  id                String         @id
  code              String         @unique
  name              String
  areaId            String
  capacity          Int
  status            TableStatus
  activeBookingId   Int?
  activeBookingCode String         @default("")
  occupiedAt        DateTime?
  releasedAt        DateTime?
  note              String         @default("")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  bookingLinks      BookingTable[]
  area              TableArea      @relation(fields: [areaId], references: [id])

  @@index([areaId])
  @@index([status])
}

model Booking {
  id                  Int            @id @default(autoincrement())
  bookingCode         String         @unique
  guests              Int
  date                String
  time                String
  seatingArea         String         @default("KHONG_UU_TIEN")
  notes               String         @default("")
  name                String
  phone               String
  email               String         @default("")
  status              BookingStatus
  source              String         @default("web")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  userEmail           String?
  occasion            String         @default("")
  confirmationChannel Json?
  internalNote        String         @default("")
  checkedInAt         DateTime?
  seatedAt            DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  noShowAt            DateTime?
  createdBy           String         @default("")
  userId              Int?
  user                User?          @relation(fields: [userId], references: [id])
  bookingTables       BookingTable[]

  @@index([userId])
  @@index([status])
  @@index([date, time])
}

model BookingTable {
  bookingId  Int
  tableId    String
  assignedAt DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  table      Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([bookingId, tableId])
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  badge       String   @default("Mới")
  tone        String   @default("tone-amber")
  image       String   @default("")
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]

  @@index([category])
  @@index([isAvailable])
}

model Order {
  id                 Int                  @id @default(autoincrement())
  maDonHang          String               @unique
  subtotal           Decimal              @db.Decimal(10, 2)
  serviceFee         Decimal              @db.Decimal(10, 2)
  discountAmount     Decimal              @db.Decimal(10, 2)
  voucherCode        String               @default("")
  total              Decimal              @db.Decimal(10, 2)
  orderDate          DateTime             @default(now())
  status             TrangThaiDonHang     @default(MOI_TAO)
  paymentStatus      TrangThaiThanhToan   @default(CHUA_THANH_TOAN)
  note               String               @default("")
  tableNumber        String               @default("")
  paymentMethod      PhuongThucThanhToan  @default(TIEN_MAT)
  userEmail          String               @default("")
  customerFullName   String               @default("")
  customerPhone      String               @default("")
  customerEmail      String               @default("")
  customerAddress    String               @default("")
  customerSnapshot   Json?
  userId             Int?
  user               User?                @relation(fields: [userId], references: [id])
  items              OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderDate])
}

model OrderItem {
  id               Int       @id @default(autoincrement())
  orderId          Int
  menuItemId       Int?
  name             String
  price            Decimal   @db.Decimal(10, 2)
  quantity         Int
  selectedSize     String    @default("M")
  selectedToppings Json?
  specialNote      String    @default("")
  variantKey       String    @default("")
  itemSnapshot     Json?
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem         MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Voucher {
  id                Int                  @id @default(autoincrement())
  code              String               @unique
  name              String
  description       String               @default("")
  discountType      VoucherDiscountType  @default(FIXED)
  discountValue     Decimal              @db.Decimal(10, 2)
  minOrderAmount    Decimal              @default(0) @db.Decimal(10, 2)
  maxDiscountAmount Decimal?             @db.Decimal(10, 2)
  startsAt          DateTime?
  endsAt            DateTime?
  usageLimit        Int?
  usedCount         Int                  @default(0)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([isActive])
  @@index([startsAt, endsAt])
}
