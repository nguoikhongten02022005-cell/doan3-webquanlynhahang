{
  "name": "quan-ly-nha-hang-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Dieu phoi frontend React/Vite va backend NestJS",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend/nest-api run start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend/nest-api run build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend/nest-api run lint",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend/nest-api run test",
    "check": "npm run lint && npm run build && npm run test",
    "preview": "npm --prefix frontend run preview",
    "smoke:api": "bash -lc 'set -a && source .env && set +a && node scripts/smoke-api.mjs'"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.3.0",
    "swagger-ui-express": "^5.0.1"
  }
}
